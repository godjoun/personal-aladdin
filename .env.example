# Project Aladdin Personal — 환경 변수 예시
# 사용: 이 파일을 복사해 ".env" 로 저장 후 값을 채우고 npm run dev 재시작

# ETF 시세 API
BASE_URL=https://apis.data.go.kr/1160100/service/GetSecuritiesProductInfoService/getETFPriceInfo

# 일반 주식 시세 API (금융위원회_주식시세정보)
STOCK_BASE_URL=https://apis.data.go.kr/1160100/service/GetStockSecuritiesInfoService/getStockPriceInfo

# 공공데이터포털 인증키 (ETF·주식 API 공통)
API_KEY=여기에_인증키_입력

# ── ALADDIN Central Host (중앙 서버) ──
CENTRAL_PORT=3001
ADMIN_KEY=여기에_관리자_비밀키_입력

# 프론트엔드 → 중앙 서버 주소
# 로컬 개발: http://localhost:3001
# Render 등 배포: 비워 두면 자동(같은 주소)
VITE_CENTRAL_API_URL=http://localhost:3001
